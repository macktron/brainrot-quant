OPENAI_API_KEY=sk-...
# Polymarket private key (Ethereum key for signing orders)
POLYMARKET_PRIVATE_KEY=
# Discord webhook URL for trade notifications
DISCORD_WEBHOOK_URL=


# Polymarket L2 API credentials (run api-key.py to generate)
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# Proxy wallet address shown at polymarket.com/settings
POLY_FUNDER=

# Set to false for live trading (default: true = paper trade)
DRY_RUN=true
# Fraction of balance to bet per trade (default: 0.20 = 20%)
BET_FRACTION=0.20
# Max trades per pipeline run (default: 4)
MAX_TRADES_PER_RUN=4

# Paper mode: filter active markets like live using history/API positions (default: true)
PAPER_RESPECT_EXPOSURE=true
# Paper mode: hypothetical USDC balance for logged bet sizes only (0 = omit)
PAPER_ASSUMED_BALANCE_USDC=0

# Discord: one embed per filled live order (not skips/paper/failed orders)
DISCORD_NOTIFY_EXECUTED_TRADES=true
# Summary embed: short LLM explanation of why trades did/did not run
DISCORD_SUMMARY_LLM=true

# Leader market: if YES or NO price >= this on an *open* market, treat outcome as known (0 = disable)
LEADER_PRICE_CERTAINTY_THRESHOLD=0.9

# Min order size in USDC (lower if balance ~$10 and sizing stays under default $2)
MIN_BET_USDC=2
