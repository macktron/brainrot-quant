OPENAI_API_KEY=sk-...
# Polymarket private key (Ethereum key for signing orders)
POLYMARKET_PRIVATE_KEY=
# Discord webhook URL for trade notifications
DISCORD_WEBHOOK_URL=


# Polymarket L2 API credentials (run api-key.py to generate)
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# Proxy wallet address shown at polymarket.com/settings
POLY_FUNDER=

# Set to false for live trading (default: true = paper trade)
DRY_RUN=true
# Fraction of balance to bet per trade (default: 0.20 = 20%)
BET_FRACTION=0.20
# Max trades per pipeline run (default: 4)
MAX_TRADES_PER_RUN=4

# Exposure Management
# Skip markets we already have positions in (default: false)
# Set to true to never add to existing positions
SKIP_EXPOSED_MARKETS=false
# Max exposure per market as fraction of balance (default: 0.30 = 30%)
# New trades are capped to not exceed this limit per market
MAX_EXPOSURE_PER_MARKET=0.30
