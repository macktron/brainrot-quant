OPENAI_API_KEY=sk-...
# Polymarket private key (Ethereum key for signing orders)
POLYMARKET_PRIVATE_KEY=
# Discord webhook URL for trade notifications
DISCORD_WEBHOOK_URL=
# USDC amount per trade (default: 5)
TRADE_SIZE_USDC=5
# Set to false to enable live trading (default: true = dry run)
DRY_RUN=true
