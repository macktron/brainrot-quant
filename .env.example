OPENAI_API_KEY=sk-...
# Polymarket private key (Ethereum key for signing orders)
POLYMARKET_PRIVATE_KEY=
# Discord webhook URL for trade notifications
DISCORD_WEBHOOK_URL=

# Set to false for live trading (default: true = paper trade)
DRY_RUN=true
# Fraction of balance to bet per trade (default: 0.20 = 20%)
BET_FRACTION=0.20
# Max trades per pipeline run (default: 4)
MAX_TRADES_PER_RUN=4
